{
  "expo": {
    "name": "Schreinerei Kiwi",
    "slug": "schreinerei-kiwi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/kiwi-icon.png",
    "scheme": "schreinereiKiwi",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.bisasam.schreinereiKiwi",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/kiwi-icon.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/kiwi-icon.png",
          "imageWidth": 160,
          "resizeMode": "contain",
          "backgroundColor": "#004e2a",
          "dark": {
            "backgroundColor": "#004e2a"
          }
        }
      ],
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "photosPermission": "Schreinerei Kiwi benötigt Zugriff auf Ihre Fotos, um Belege zu scannen.",
          "cameraPermission": "Schreinerei Kiwi benötigt Zugriff auf die Kamera, um Belege zu fotografieren."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "f1856b9b-5523-40a0-a57e-a997f8137656"
      }
    }
  }
}
