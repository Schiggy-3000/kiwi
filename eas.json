{
  "cli": {
    "version": ">= 18.3.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "applicationId": "com.bisasam.schreinereiKiwi",
        "track": "internal",
        "releaseStatus": "draft",
        "serviceAccountKeyPath": "./temp/gcp_service_account_private_key.json"
      }
    }
  }
}
